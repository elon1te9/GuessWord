@inject NavigationManager Nav

<div class="topbar">
    <div class="topbar-left">

        <button class="nav-btn @(IsActive("/") ? "active" : "")" @onclick='() => Go("/")'>
            <i class="bi bi-house"></i>
        </button>

        <button class="nav-btn @(IsActive("/game") ? "active" : "")" @onclick='() => Go("/game")'>
            <i class="bi bi-controller"></i>
        </button>

        <button class="nav-btn @(IsActive("/leaderboard") ? "active" : "")" @onclick='() => Go("/leaderboard")'>
            <i class="bi bi-bar-chart"></i>
        </button>

        <button class="nav-btn @(IsActive("/login") ? "active" : "")" @onclick='() => Go("/login")'>
            <i class="bi bi-person"></i>
        </button>

    </div>

    <div class="logo" @onclick='() => Go("/")'>
        GuessWord
    </div>
</div>

@code {
    void Go(string url) => Nav.NavigateTo(url);

    bool IsActive(string url)
    {
        var current = "/" + Nav.ToBaseRelativePath(Nav.Uri).Trim('/');
        if (current == "//") current = "/";
        return current == url;
    }
}
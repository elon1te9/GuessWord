@implements IDisposable
@inject NavigationManager Nav
@inject GuessWord.Client.Services.UserStateService UserState

<div class="topbar">
    <div class="topbar-left">
        @foreach (var item in NavItems)
        {
            <button class="@GetNavButtonClass(item)" @onclick='() => Go(item.Url)'>
                <i class="@item.Icon"></i>
            </button>
        }

        <button class="@GetProfileButtonClass()" @onclick='GoToProfileOrLogin'>
            <i class="bi bi-person"></i>
        </button>
    </div>

    <div class="logo" @onclick='() => Go("/")'>
        GuessWord
    </div>
</div>

@code {
    private readonly List<NavItem> NavItems =
    [
        new("/", "bi bi-house"),
        new("/game", "bi bi-controller"),
        new("/leaderboard", "bi bi-bar-chart")
    ];

    private string ProfileOrLoginUrl => UserState.IsAuthorized ? "/profile" : "/login";

    protected override void OnInitialized()
    {
        UserState.OnChange += HandleUserStateChanged;
        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleUserStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void Go(string url)
    {
        Nav.NavigateTo(url);
    }

    private void GoToProfileOrLogin()
    {
        Nav.NavigateTo(ProfileOrLoginUrl);
    }

    private string GetNavButtonClass(NavItem item)
    {
        return IsActive(item.Url) ? "nav-btn active" : "nav-btn";
    }

    private string GetProfileButtonClass()
    {
        return IsProfileSectionActive() ? "nav-btn active" : "nav-btn";
    }

    private bool IsProfileSectionActive()
    {
        return IsActive("/login") || IsActive("/profile");
    }

    private bool IsActive(string url)
    {
        var current = GetCurrentPath();

        return url == "/"
            ? current == "/"
            : string.Equals(current, url, StringComparison.OrdinalIgnoreCase)
              || current.StartsWith($"{url}/", StringComparison.OrdinalIgnoreCase);
    }

    private string GetCurrentPath()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        if (string.IsNullOrWhiteSpace(relativePath))
            return "/";

        var pathWithoutQuery = relativePath.Split('?', '#')[0].Trim('/');
        return string.IsNullOrEmpty(pathWithoutQuery) ? "/" : "/" + pathWithoutQuery;
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
        Nav.LocationChanged -= HandleLocationChanged;
    }

    private sealed record NavItem(string Url, string Icon);
}

@using GuessWord.Shared.Responses

@if (Attempts.Count > 0)
{
    <div class="single-game-word-table">
        @foreach (var attempt in Attempts)
        {
            <AttemptCard @key="GetAttemptKey(attempt)"
                         Attempt="attempt"
                         IsActive="@(HighlightLastSubmitted && IsLastSubmittedWord(attempt))" />
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<GameAttemptResponseDto> Attempts { get; set; } = Array.Empty<GameAttemptResponseDto>();

    [Parameter]
    public GameAttemptResponseDto? LastSubmittedAttempt { get; set; }

    [Parameter]
    public bool HighlightLastSubmitted { get; set; }

    private bool IsLastSubmittedWord(GameAttemptResponseDto attempt)
    {
        return LastSubmittedAttempt is not null &&
               string.Equals(attempt.Word, LastSubmittedAttempt.Word, StringComparison.OrdinalIgnoreCase) &&
               attempt.CreatedAt == LastSubmittedAttempt.CreatedAt &&
               attempt.Rank == LastSubmittedAttempt.Rank;
    }

    private static string GetAttemptKey(GameAttemptResponseDto attempt)
    {
        return $"{attempt.Word}|{attempt.Rank}|{attempt.CreatedAt:O}";
    }
}

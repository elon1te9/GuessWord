@using GuessWord.Shared.Responses
@using GuessWord.Client.Services

@if (Attempts.Count > 0)
{
    <div class="single-game-word-table">
        @foreach (var attempt in Attempts)
        {
            <AttemptCard @key="GetAttemptKey(attempt)"
                         Attempt="attempt" />
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<GameAttemptResponseDto> Attempts { get; set; } = Array.Empty<GameAttemptResponseDto>();

    private static string GetAttemptKey(GameAttemptResponseDto attempt)
    {
        return GameAttemptDisplayHelper.BuildAttemptKey(attempt);
    }
}

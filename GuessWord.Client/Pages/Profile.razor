@page "/profile"
@implements IDisposable
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState
@inject GuessWord.Client.Services.AuthService AuthService

<PageTitle>Профиль</PageTitle>

<div class="profile-page">
    @if (!UserState.IsAuthorized)
    {
        <section class="profile-card profile-empty-card">
            <h1 class="profile-empty-title">Профиль</h1>
            <p class="profile-empty-text">Войдите в аккаунт, чтобы открыть профиль.</p>
            <button class="profile-login-button" @onclick="NavigateToLogin" type="button">Войти</button>
        </section>
    }
    else
    {
        <section class="profile-card profile-header">
            <div class="profile-header-content">
                <h1 class="profile-name">@DisplayName</h1>
                <p class="profile-subtitle">Твой профиль и игровые достижения</p>
            </div>

            <button class="profile-logout-button" @onclick="Logout" type="button">Выйти</button>
        </section>

        <div class="profile-stats">
            <section class="profile-stat-card">
                <div class="profile-stat-value">0</div>
                <div class="profile-stat-label">Количество игр</div>
            </section>

            <section class="profile-stat-card">
                <div class="profile-stat-value">0</div>
                <div class="profile-stat-label">Количество побед</div>
            </section>

            <section class="profile-stat-card">
                <div class="profile-stat-value">0%</div>
                <div class="profile-stat-label">Процент побед</div>
            </section>
        </div>

        <section class="profile-card profile-history-card">
            <button class="profile-history-button" @onclick="NavigateToHistory" type="button">История</button>

            <div class="profile-history-content">
                <h2 class="profile-history-title">История матчей</h2>
                <p class="profile-history-text">
                    Открой последние матчи, сравни результаты одиночных и мультиплеерных сессий и найди лучшие попытки.
                </p>
            </div>
        </section>
    }
</div>

@code {
    private string DisplayName =>
        !string.IsNullOrWhiteSpace(UserState.Name) ? UserState.Name! :
        !string.IsNullOrWhiteSpace(UserState.Login) ? UserState.Login! :
        "Пользователь";

    protected override void OnInitialized()
    {
        UserState.OnChange += HandleUserStateChanged;
    }

    private void HandleUserStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void NavigateToHistory()
    {
        Navigation.NavigateTo("/history");
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
    }
}

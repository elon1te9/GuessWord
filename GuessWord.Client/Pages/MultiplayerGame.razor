@page "/game/multiplayer/{GameId:int}"
@implements IAsyncDisposable
@using GuessWord.Client.Components.Game
@using GuessWord.Shared.Enums
@using GuessWord.Shared.Responses
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState
@inject GuessWord.Client.Services.GameService GameService
@inject GuessWord.Client.Services.ApiSettings ApiSettings

<PageTitle>РРіСЂР° 1 РЅР° 1</PageTitle>

<div class="single-game-page">
    @if (isLoading)
    {
        <p class="single-game-message">Р—Р°РіСЂСѓР·РєР°...</p>
    }
    else if (!UserState.IsAuthorized)
    {
        <section class="single-game-card single-game-empty-card">
            <h1 class="single-game-title">РРіСЂР° 1 РЅР° 1</h1>
            <p class="single-game-message">Р’РѕР№РґРёС‚Рµ РІ Р°РєРєР°СѓРЅС‚, С‡С‚РѕР±С‹ РёРіСЂР°С‚СЊ.</p>
            <button class="single-game-button single-game-button-light" @onclick="NavigateToLogin" type="button">
                Р’РѕР№С‚Рё
            </button>
        </section>
    }
    else if (currentGame is null)
    {
        <section class="single-game-card single-game-empty-card">
            <h1 class="single-game-title">РРіСЂР° РЅРµ РЅР°Р№РґРµРЅР°</h1>
            <p class="single-game-message">РќРµ СѓРґР°Р»РѕСЃСЊ Р·Р°РіСЂСѓР·РёС‚СЊ multiplayer-РёРіСЂСѓ.</p>

            @if (!string.IsNullOrWhiteSpace(pageMessage))
            {
                <p class="single-game-message">@pageMessage</p>
            }

            <button class="single-game-button single-game-button-dark" @onclick="NavigateToLobby" type="button">
                Р’ Р»РѕР±Р±Рё
            </button>
        </section>
    }
    else
    {
        <section class="single-game-card single-game-header">
            <div class="single-game-header-main">
                <div>
                    <h1 class="single-game-title">РРіСЂР° 1 РЅР° 1</h1>
                    <p class="single-game-subtitle">РћР±С‰РёР№ СЂР°СѓРЅРґ РїСЂРѕС‚РёРІ СЃРѕРїРµСЂРЅРёРєР°</p>
                </div>

                <div class="single-game-header-actions">
                    <div class="single-game-meta">РџРѕРїС‹С‚РєРё: @GetAttemptsCount()</div>
                    <button class="single-game-button single-game-button-light" @onclick="NavigateToLobby" type="button">
                        Р’ Р»РѕР±Р±Рё
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(signalRErrorMessage))
            {
                <p class="single-game-message">@signalRErrorMessage</p>
            }

            <form class="single-game-form" @onsubmit="SubmitGuessAsync" @onsubmit:preventDefault="true">
                <input class="single-game-input"
                       @ref="guessInputRef"
                       @bind="guessWord"
                       @bind:event="oninput"
                       disabled="@(isSubmitting || currentGame.Status == GameStatus.Finished)"
                       placeholder="Р’РІРµРґРёС‚Рµ СЃР»РѕРІРѕ" />

                <button class="single-game-button single-game-button-dark"
                        disabled="@(isSubmitting || currentGame.Status == GameStatus.Finished)"
                        type="submit">
                    @(isSubmitting ? "РџСЂРѕРІРµСЂРєР°..." : "РџСЂРѕРІРµСЂРёС‚СЊ")
                </button>
            </form>

            @if (!string.IsNullOrWhiteSpace(pageMessage) && pageMessage != "Р­С‚Рѕ СЃР»РѕРІРѕ СѓР¶Рµ Р±С‹Р»Рѕ РІРІРµРґРµРЅРѕ.")
            {
                <p class="single-game-message">@pageMessage</p>
            }
        </section>

        <section class="single-game-card">
            <h2 class="single-game-title">РЎРѕРїРµСЂРЅРёРє</h2>
            <div class="single-game-message">@GetOpponentName()</div>
            <div class="single-game-message">Р›СѓС‡С€РёР№ СЂР°РЅРі: @(GetOpponentBestRank()?.ToString() ?? "вЂ”")</div>
            <div class="single-game-message">РџРѕРїС‹С‚РєРё: @GetOpponentAttemptsCount()</div>
        </section>

        @if (lastSubmittedAttempt is not null || showNotFoundCard || displayAttempts.Count > 0)
        {
            <section class="single-game-card single-game-attempts-card">
                @if (lastSubmittedAttempt is not null)
                {
                    <AttemptCard Attempt="lastSubmittedAttempt"
                                 IsFeatured="true"
                                 IsActive="true" />
                }
                else if (showNotFoundCard)
                {
                    <div class="single-game-word-not-found">
                        С‚Р°РєРѕРіРѕ СЃР»РѕРІР° РЅРµ РЅР°Р№РґРµРЅРѕ
                    </div>
                }

                @if (displayAttempts.Count > 0)
                {
                    <AttemptList Attempts="displayAttempts"
                                 LastSubmittedAttempt="lastSubmittedAttempt" />
                }
            </section>
        }
    }
</div>

@if (currentGame is not null && currentGame.Status == GameStatus.Finished)
{
    <div class="single-game-result-overlay">
        <div class="single-game-result-modal">
            <div class="single-game-result-pill">Р Р°СѓРЅРґ Р·Р°РІРµСЂС€С‘РЅ</div>
            <h2 class="single-game-result-title">@GetResultTitle()</h2>
            <p class="single-game-result-text">@GetResultText()</p>

            <div class="single-game-result-secret">
                <div class="single-game-result-secret-label">Р”Р»РёРЅР° СЃРµРєСЂРµС‚РЅРѕРіРѕ СЃР»РѕРІР°</div>
                <div class="single-game-result-secret-word">@currentGame.SecretWordLength</div>
            </div>

            <div class="single-game-result-stats">
                <div class="single-game-result-stat">
                    <div class="single-game-result-stat-label">РџРѕРїС‹С‚РєРё</div>
                    <div class="single-game-result-stat-value">@GetAttemptsCount()</div>
                </div>

                <div class="single-game-result-stat">
                    <div class="single-game-result-stat-label">Р РµР·СѓР»СЊС‚Р°С‚</div>
                    <div class="single-game-result-stat-value">@GetResultValue()</div>
                </div>
            </div>

            <div class="single-game-result-actions">
                <button class="single-game-button single-game-button-dark" @onclick="NavigateToLobby" type="button">
                    Р’ Р»РѕР±Р±Рё
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int GameId { get; set; }

    private bool isLoading = true;
    private bool isSubmitting;
    private bool showNotFoundCard;
    private bool shouldFocusGuessInput;
    private string guessWord = string.Empty;
    private string pageMessage = string.Empty;
    private string? signalRErrorMessage;
    private ElementReference guessInputRef;
    private GameStateDto? currentGame;
    private GameAttemptResponseDto? lastSubmittedAttempt;
    private List<GameAttemptResponseDto> displayAttempts = new();
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsAuthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadGameState(GameId);

        if (currentGame is not null)
            await InitializeSignalRAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldFocusGuessInput)
            return;

        shouldFocusGuessInput = false;

        if (currentGame is null || currentGame.Status == GameStatus.Finished || isSubmitting)
            return;

        await guessInputRef.FocusAsync();
    }

    private async Task LoadGameState(int gameId)
    {
        pageMessage = string.Empty;
        guessWord = string.Empty;
        lastSubmittedAttempt = null;
        showNotFoundCard = false;

        currentGame = await GameService.GetGameStateAsync(gameId);
        UpdateDisplayAttempts();
        isLoading = false;

        if (currentGame is null)
            pageMessage = "РќРµ СѓРґР°Р»РѕСЃСЊ РїРѕР»СѓС‡РёС‚СЊ СЃРѕСЃС‚РѕСЏРЅРёРµ multiplayer-РёРіСЂС‹.";
    }

    private async Task InitializeSignalRAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(new Uri(ApiSettings.BaseUrl), "hubs/game"), options =>
            {
                options.AccessTokenProvider = () => Task.FromResult(UserState.Token);
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int>("GameUpdated", async updatedGameId =>
        {
            if (updatedGameId == GameId)
                await ReloadGameStateAsync();
        });

        hubConnection.Reconnected += async _ =>
        {
            await hubConnection.InvokeAsync("JoinGameGroup", GameId);
            await ReloadGameStateAsync();
        };

        try
        {
            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinGameGroup", GameId);
            signalRErrorMessage = null;
        }
        catch
        {
            signalRErrorMessage = "РђРІС‚РѕРѕР±РЅРѕРІР»РµРЅРёРµ РёРіСЂС‹ РЅРµРґРѕСЃС‚СѓРїРЅРѕ.";
        }
    }

    private async Task ReloadGameStateAsync()
    {
        await LoadGameState(GameId);
        await InvokeAsync(StateHasChanged);
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void NavigateToLobby()
    {
        Navigation.NavigateTo("/game");
    }

    private async Task SubmitGuessAsync()
    {
        if (currentGame is null || isSubmitting || currentGame.Status == GameStatus.Finished)
            return;

        var trimmedWord = guessWord.Trim();

        if (string.IsNullOrWhiteSpace(trimmedWord))
        {
            pageMessage = "Р’РІРµРґРёС‚Рµ СЃР»РѕРІРѕ.";
            return;
        }

        isSubmitting = true;
        pageMessage = string.Empty;

        var updatedGame = await GameService.SubmitMultiplayerGuessAsync(GameId, trimmedWord);

        isSubmitting = false;

        if (updatedGame is null)
        {
            pageMessage = "РќРµ СѓРґР°Р»РѕСЃСЊ РѕС‚РїСЂР°РІРёС‚СЊ СЃР»РѕРІРѕ.";
            shouldFocusGuessInput = true;
            return;
        }

        await LoadGameState(GameId);
        guessWord = string.Empty;

        var latestAttempt = updatedGame.LastAttempt;

        if (latestAttempt is null)
        {
            lastSubmittedAttempt = null;
            showNotFoundCard = false;
            shouldFocusGuessInput = true;
            return;
        }

        if (!latestAttempt.IsValid)
        {
            lastSubmittedAttempt = null;
            showNotFoundCard = true;
            pageMessage = string.Empty;
            shouldFocusGuessInput = true;
            return;
        }

        if (updatedGame.LastAttemptWasRepeated)
        {
            lastSubmittedAttempt = latestAttempt;
            showNotFoundCard = false;
            pageMessage = "Р­С‚Рѕ СЃР»РѕРІРѕ СѓР¶Рµ Р±С‹Р»Рѕ РІРІРµРґРµРЅРѕ.";
            shouldFocusGuessInput = true;
            return;
        }

        lastSubmittedAttempt = latestAttempt;
        showNotFoundCard = false;
        pageMessage = string.Empty;
        shouldFocusGuessInput = true;
    }

    private void UpdateDisplayAttempts()
    {
        displayAttempts = BuildDisplayAttempts();
    }

    private List<GameAttemptResponseDto> BuildDisplayAttempts()
    {
        var attempts = GetCurrentPlayer()?.Attempts;

        if (attempts is null)
            return [];

        return attempts
            .Where(attempt => attempt.Rank.HasValue)
            .GroupBy(attempt => attempt.Word.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(group => group.OrderBy(attempt => attempt.Rank).ThenBy(attempt => attempt.CreatedAt).First())
            .OrderBy(attempt => attempt.Rank)
            .ThenBy(attempt => attempt.Word)
            .Select(attempt => new GameAttemptResponseDto
            {
                Word = attempt.Word,
                Rank = attempt.Rank,
                IsValid = true,
                CreatedAt = attempt.CreatedAt
            })
            .ToList();
    }

    private GamePlayerStateDto? GetCurrentPlayer()
    {
        return currentGame?.Players.FirstOrDefault(player => player.UserId == UserState.UserId);
    }

    private GamePlayerStateDto? GetOpponent()
    {
        return currentGame?.Players.FirstOrDefault(player => player.UserId != UserState.UserId);
    }

    private int GetAttemptsCount()
    {
        return GetCurrentPlayer()?.Attempts.Count ?? 0;
    }

    private string GetOpponentName()
    {
        return GetOpponent()?.Username ?? "РЎРѕРїРµСЂРЅРёРє";
    }

    private int GetOpponentAttemptsCount()
    {
        return GetOpponent()?.Attempts.Count ?? 0;
    }

    private int? GetOpponentBestRank()
    {
        return GetOpponent()?.Attempts
            .Where(attempt => attempt.Rank.HasValue)
            .Min(attempt => attempt.Rank);
    }

    private bool IsCurrentUserWinner()
    {
        return currentGame?.WinnerId == UserState.UserId;
    }

    private string GetResultTitle()
    {
        if (currentGame is null)
            return "РРіСЂР° Р·Р°РІРµСЂС€РµРЅР°";

        return IsCurrentUserWinner()
            ? "РџРѕР±РµРґР°!"
            : "РџРѕСЂР°Р¶РµРЅРёРµ";
    }

    private string GetResultText()
    {
        if (currentGame is null)
            return "Р Р°СѓРЅРґ Р·Р°РІРµСЂС€С‘РЅ";

        return IsCurrentUserWinner()
            ? "РўС‹ РѕР±РѕС€С‘Р» СЃРѕРїРµСЂРЅРёРєР°"
            : "РЎРѕРїРµСЂРЅРёРє РѕРєР°Р·Р°Р»СЃСЏ Р±Р»РёР¶Рµ";
    }

    private string GetResultValue()
    {
        if (currentGame is null)
            return "Р—Р°РІРµСЂС€РµРЅР°";

        return IsCurrentUserWinner()
            ? "РџРѕР±РµРґР°"
            : "РџРѕСЂР°Р¶РµРЅРёРµ";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is null)
            return;

        try
        {
            if (hubConnection.State is HubConnectionState.Connected or HubConnectionState.Reconnecting)
                await hubConnection.InvokeAsync("LeaveGameGroup", GameId);
        }
        catch
        {
        }

        await hubConnection.DisposeAsync();
    }
}

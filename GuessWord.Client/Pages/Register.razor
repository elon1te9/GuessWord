@page "/register"
@inject GuessWord.Client.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-title">Регистрация</div>

        <div class="auth-field">
            <label class="auth-label">Имя:</label>
            <input class="auth-input" @bind="name" placeholder="Имя" />
        </div>

        <div class="auth-field">
            <label class="auth-label">Логин:</label>
            <input class="auth-input" @bind="login" placeholder="Логин" />
        </div>

        <div class="auth-field">
            <label class="auth-label">Пароль:</label>
            <input class="auth-input" type="password" @bind="password" placeholder="Пароль" />
        </div>

        <div class="auth-message">@errorMessage</div>

        <button class="auth-button" @onclick="RegisterUser" type="button">
            Зарегистрироваться
        </button>

        <div class="auth-footer-text">
            <span class="auth-footer-question">Уже есть аккаунт?</span>
            <a href="/login">Войти</a>
        </div>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string login = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task RegisterUser()
    {
        if (string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(login) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Заполните все поля!";
            return;
        }

        errorMessage = string.Empty;

        var result = await AuthService.Register(new GuessWord.Shared.Requests.RegisterRequestDto
        {
            Name = name,
            Login = login,
            Password = password
        });

        if (result is null)
        {
            errorMessage = "Не удалось зарегистрироваться.";
            return;
        }

        Navigation.NavigateTo("/");
    }
}
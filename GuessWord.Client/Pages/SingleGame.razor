@page "/game/single"
@implements IDisposable
@using Microsoft.AspNetCore.Components
@using GuessWord.Client.Components.Game
@using GuessWord.Shared.Enums
@using GuessWord.Shared.Responses
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState
@inject GuessWord.Client.Services.GameService GameService

<PageTitle>Одиночная игра</PageTitle>

<div class="single-game-page">
    @if (isLoading)
    {
        <p class="single-game-message">Загрузка...</p>
    }
    else if (!UserState.IsAuthorized)
    {
        <section class="single-game-card single-game-empty-card">
            <h1 class="single-game-title">Одиночная игра</h1>
            <p class="single-game-message">Войдите в аккаунт, чтобы играть.</p>
            <button class="single-game-button single-game-button-light" @onclick="NavigateToLogin" type="button">
                Войти
            </button>
        </section>
    }
    else if (currentGame is null)
    {
        <section class="single-game-card single-game-empty-card">
            <h1 class="single-game-title">Нет активной игры</h1>
            <p class="single-game-message">Начните новую одиночную игру.</p>

            <button class="single-game-button single-game-button-dark"
                    @onclick="StartNewGameAsync"
                    disabled="@isStartingGame"
                    type="button">
                @(isStartingGame ? "Запуск..." : "Начать игру")
            </button>

            @if (!string.IsNullOrWhiteSpace(pageMessage))
            {
                <p class="single-game-message">@pageMessage</p>
            }
        </section>
    }
    else
    {
        <section class="single-game-card single-game-header">
            <div class="single-game-header-main">
                <div>
                    <h1 class="single-game-title">Одиночная игра</h1>
                    <p class="single-game-subtitle">Вводи слова и ориентируйся на ранг</p>
                </div>

                <div class="single-game-header-actions">
                    <div class="single-game-meta">Попытки: @currentGame.AttemptsCount</div>
                    <button class="single-game-button single-game-button-danger single-game-button-steady"
                            @onclick="GiveUpAsync"
                            disabled="@(isSubmitting || currentGame.Status == GameStatus.Finished)"
                            type="button">
                        Сдаться
                    </button>
                    <button class="single-game-button single-game-button-light" @onclick="NavigateToLobby" type="button">
                        В лобби
                    </button>
                </div>
            </div>

            <form class="single-game-form" @onsubmit="SubmitGuessAsync" @onsubmit:preventDefault="true">
                <input class="single-game-input"
                       @ref="guessInputRef"
                       @bind="guessWord"
                       @bind:event="oninput"
                       disabled="@(isSubmitting || currentGame.Status == GameStatus.Finished)"
                       placeholder="Введите слово" />

                <button class="single-game-button single-game-button-dark single-game-button-steady"
                        disabled="@(isSubmitting || currentGame.Status == GameStatus.Finished)"
                        type="submit">
                    Проверить
                </button>
            </form>

            @if (!string.IsNullOrWhiteSpace(pageMessage) && pageMessage != "Это слово уже было введено.")
            {
                <p class="single-game-message">@pageMessage</p>
            }
        </section>

        @if (lastSubmittedAttempt is not null || showNotFoundCard || displayAttempts.Count > 0)
        {
            <section class="single-game-card single-game-attempts-card">
                @if (lastSubmittedAttempt is not null)
                {
                    <AttemptCard @key="GetAttemptKey(lastSubmittedAttempt)"
                                 Attempt="lastSubmittedAttempt"
                                 IsFeatured="true"
                                 IsActive="true" />
                }
                else if (showNotFoundCard)
                {
                    <div class="single-game-word-not-found">
                        такого слова не найдено
                    </div>
                }

                @if (displayAttempts.Count > 0)
                {
                    <AttemptList Attempts="displayAttempts"
                                 LastSubmittedAttempt="lastSubmittedAttempt" />
                }
            </section>
        }
    }
</div>

@if (currentGame is not null && currentGame.Status == GameStatus.Finished)
{
    <GameResultModal CurrentGame="currentGame"
                     IsStartingGame="isStartingGame"
                     OnStartNewGame="StartNewGameAsync"
                     OnNavigateToLobby="NavigateToLobby" />
}

@code {
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isStartingGame;
    private bool showNotFoundCard;
    private bool shouldFocusGuessInput;
    private string guessWord = string.Empty;
    private string pageMessage = string.Empty;
    private ElementReference guessInputRef;
    private SingleGameResponseDto? currentGame;
    private GameAttemptResponseDto? lastSubmittedAttempt;
    private List<GameAttemptResponseDto> displayAttempts = new();

    protected override async Task OnInitializedAsync()
    {
        UserState.OnChange += HandleUserStateChanged;
        await LoadCurrentGameAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldFocusGuessInput)
            return;

        shouldFocusGuessInput = false;

        if (currentGame is null || currentGame.Status == GameStatus.Finished || isSubmitting)
            return;

        await guessInputRef.FocusAsync();
    }

    private void HandleUserStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadCurrentGameAsync();
            StateHasChanged();
        });
    }

    private async Task LoadCurrentGameAsync()
    {
        pageMessage = string.Empty;
        guessWord = string.Empty;
        lastSubmittedAttempt = null;
        showNotFoundCard = false;

        if (!UserState.IsAuthorized)
        {
            currentGame = null;
            displayAttempts = new();
            isLoading = false;
            return;
        }

        isLoading = true;
        currentGame = await GameService.GetCurrentSingleGameAsync();
        UpdateDisplayAttempts();
        isLoading = false;
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void NavigateToLobby()
    {
        Navigation.NavigateTo("/game");
    }

    private async Task StartNewGameAsync()
    {
        if (isStartingGame || !UserState.IsAuthorized)
            return;

        isStartingGame = true;
        pageMessage = string.Empty;

        var startedGame = await GameService.StartSingleGameAsync();

        isStartingGame = false;

        if (startedGame is null)
        {
            pageMessage = "Не удалось начать игру. Попробуйте ещё раз.";
            return;
        }

        currentGame = startedGame;
        UpdateDisplayAttempts();
        lastSubmittedAttempt = null;
        showNotFoundCard = false;
        guessWord = string.Empty;
    }

    private async Task SubmitGuessAsync()
    {
        if (currentGame is null || isSubmitting || currentGame.Status == GameStatus.Finished)
            return;

        var trimmedWord = guessWord.Trim();

        if (string.IsNullOrWhiteSpace(trimmedWord))
        {
            pageMessage = "Введите слово.";
            return;
        }

        isSubmitting = true;
        pageMessage = string.Empty;

        var updatedGame = await GameService.SubmitGuessAsync(currentGame.GameId, trimmedWord);

        isSubmitting = false;

        if (updatedGame is null)
        {
            pageMessage = "Не удалось отправить слово.";
            shouldFocusGuessInput = true;
            return;
        }

        var latestAttempt = updatedGame.LastAttempt;

        if (latestAttempt is null)
        {
            lastSubmittedAttempt = null;
            showNotFoundCard = false;
        }
        else if (!latestAttempt.IsValid)
        {
            lastSubmittedAttempt = null;
            showNotFoundCard = true;
            pageMessage = string.Empty;
        }
        else if (updatedGame.LastAttemptWasRepeated)
        {
            lastSubmittedAttempt = latestAttempt;
            showNotFoundCard = false;
            pageMessage = "Это слово уже было введено.";
        }
        else
        {
            lastSubmittedAttempt = latestAttempt;
            showNotFoundCard = false;
            pageMessage = string.Empty;
        }

        currentGame = updatedGame;
        UpdateDisplayAttempts();
        guessWord = string.Empty;
        shouldFocusGuessInput = true;
    }

    private async Task GiveUpAsync()
    {
        if (currentGame is null || isSubmitting || currentGame.Status == GameStatus.Finished)
            return;

        isSubmitting = true;
        pageMessage = string.Empty;

        var updatedGame = await GameService.GiveUpSingleGameAsync(currentGame.GameId);

        isSubmitting = false;

        if (updatedGame is null)
        {
            pageMessage = "Не удалось завершить игру.";
            return;
        }

        currentGame = updatedGame;
        UpdateDisplayAttempts();
    }

    private void UpdateDisplayAttempts()
    {
        displayAttempts = BuildDisplayAttempts();
    }

    private List<GameAttemptResponseDto> BuildDisplayAttempts()
    {
        if (currentGame is null)
            return [];

        return currentGame.Attempts
            .Where(attempt => attempt.IsValid && attempt.Rank.HasValue)
            .GroupBy(attempt => attempt.Word.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(group => group.OrderBy(attempt => attempt.Rank).ThenBy(attempt => attempt.CreatedAt).First())
            .OrderBy(attempt => attempt.Rank)
            .ThenBy(attempt => attempt.Word)
            .ToList();
    }

    private static string GetAttemptKey(GameAttemptResponseDto attempt)
    {
        return $"{attempt.Word}|{attempt.Rank}|{attempt.CreatedAt:O}";
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
    }
}

@page "/game"
@implements IDisposable
@using GuessWord.Shared.Enums
@using GuessWord.Shared.Responses
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState
@inject GuessWord.Client.Services.GameService GameService
@inject GuessWord.Client.Services.RoomService RoomService

<PageTitle>Игровое лобби</PageTitle>

<div class="game-page">
    @if (isLoading)
    {
        <section class="game-card game-empty-card">
            <h1 class="game-title">Игровое лобби</h1>
            <p class="game-message">Загрузка...</p>
        </section>
    }
    else if (!UserState.IsAuthorized)
    {
        <section class="game-card game-empty-card">
            <h1 class="game-title">Игровое лобби</h1>
            <p class="game-message">Войдите в аккаунт, чтобы начать игру.</p>
            <button class="game-login-button" @onclick="NavigateToLogin" type="button">Войти</button>
        </section>
    }
    else
    {
        <section class="game-card game-header">
            <h1 class="game-title">Игровое лобби</h1>
            <p class="game-subtitle">Выбери режим и начни новый раунд</p>
        </section>

        @if (activeGame is not null)
        {
            <section class="game-card game-active-card">
                <h2 class="game-active-title">У тебя уже есть активная игра</h2>
                <p class="game-active-text">Заверши текущую игру, чтобы начать новую.</p>

                <div class="game-active-actions">
                    <button class="game-button game-button-dark" @onclick="ConnectToActiveGameAsync" type="button">
                        Подключиться к активной игре
                    </button>
                </div>
            </section>
        }

        <div class="game-modes-grid">
            <section class="game-card game-mode-card">
                <h2 class="game-mode-title">Одиночная игра</h2>
                <p class="game-mode-text">
                    Угадывай секретное слово по рангам и улучшай результат с каждой попыткой.
                </p>

                <div class="game-actions">
                    <button class="game-button game-button-dark"
                            @onclick="StartSingleGameAsync"
                            disabled="@(isActionLoading || HasActiveGame)"
                            type="button">
                        @(isActionLoading ? "Запуск..." : "Начать игру")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <p class="game-message">@errorMessage</p>
                }
            </section>

            <section class="game-card game-mode-card game-mode-card-accent">
                <h2 class="game-mode-title">Игра 1 на 1</h2>
                <p class="game-mode-text">
                    Соревнуйся с другим игроком в общем раунде.
                </p>

                <div class="game-actions">
                    <button class="game-button game-button-light"
                            @onclick="CreateRoomAsync"
                            disabled="@(isCreatingRoom || HasActiveGame)"
                            type="button">
                        @(isCreatingRoom ? "Создание..." : "Создать комнату")
                    </button>

                    <button class="game-button game-button-light"
                            @onclick="OpenJoinRoomModal"
                            disabled="@(isJoiningRoom || HasActiveGame)"
                            type="button">
                        Присоединиться
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(roomError))
                {
                    <div class="error-message game-message">@roomError</div>
                }
            </section>
        </div>

        <section class="game-card game-next-card">
            <h2 class="game-next-title">Что дальше?</h2>

            <ul class="game-next-list">
                <li>Начни одиночную игру</li>
                <li>Подбирай слова по рангу</li>
                <li>После завершения результат появится в истории</li>
            </ul>
        </section>
    }
</div>

@if (isJoinRoomModalOpen)
{
    <div class="single-game-result-overlay">
        <div class="single-game-result-modal game-join-modal">
            <h2 class="game-join-modal-title">Подключиться к комнате</h2>
            <p class="game-join-modal-text">Введи код комнаты, чтобы присоединиться к матчу.</p>

            <div class="game-join-modal-form">
                <input class="single-game-input"
                       @bind="joinRoomCode"
                       @bind:event="oninput"
                       disabled="@isJoiningRoom"
                       placeholder="Код комнаты" />
            </div>

            @if (!string.IsNullOrWhiteSpace(joinRoomModalError))
            {
                <p class="game-join-modal-message">@joinRoomModalError</p>
            }

            <div class="single-game-result-actions game-join-modal-actions">
                <button class="single-game-button single-game-button-light"
                        @onclick="CloseJoinRoomModal"
                        disabled="@isJoiningRoom"
                        type="button">
                    Отмена
                </button>

                <button class="single-game-button single-game-button-dark"
                        @onclick="JoinRoomAsync"
                        disabled="@isJoiningRoom"
                        type="button">
                    @(isJoiningRoom ? "Подключение..." : "Подключиться")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isActionLoading;
    private bool isCreatingRoom;
    private bool isJoiningRoom;
    private bool isJoinRoomModalOpen;
    private ActiveGameDto? activeGame;
    private string joinRoomCode = string.Empty;
    private string? roomError;
    private string? joinRoomModalError;
    private string errorMessage = string.Empty;

    private bool HasActiveGame => activeGame is not null;

    protected override async Task OnInitializedAsync()
    {
        UserState.OnChange += HandleUserStateChanged;
        await LoadLobbyStateAsync();
    }

    private void HandleUserStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadLobbyStateAsync();
            StateHasChanged();
        });
    }

    private async Task LoadLobbyStateAsync()
    {
        errorMessage = string.Empty;
        roomError = null;
        activeGame = null;

        if (!UserState.IsAuthorized)
        {
            isLoading = false;
            return;
        }

        isLoading = true;

        activeGame = await GameService.GetActiveGameAsync();

        isLoading = false;
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private Task ConnectToActiveGameAsync()
    {
        if (activeGame is null)
            return Task.CompletedTask;

        if (activeGame.GameMode == GameMode.Single)
        {
            Navigation.NavigateTo("/game/single");
            return Task.CompletedTask;
        }

        Navigation.NavigateTo($"/game/multiplayer/{activeGame.GameId}");
        return Task.CompletedTask;
    }

    private async Task StartSingleGameAsync()
    {
        if (isActionLoading || HasActiveGame)
            return;

        isActionLoading = true;
        errorMessage = string.Empty;

        var game = await GameService.StartSingleGameAsync();

        isActionLoading = false;

        if (game is null)
        {
            await LoadLobbyStateAsync();
            errorMessage = "Не удалось начать игру. Попробуйте ещё раз.";
            return;
        }

        await LoadLobbyStateAsync();
        Navigation.NavigateTo("/game/single");
    }

    private async Task CreateRoomAsync()
    {
        if (isCreatingRoom || HasActiveGame)
            return;

        isCreatingRoom = true;
        roomError = null;

        var room = await RoomService.CreateRoomAsync();

        isCreatingRoom = false;

        if (room is null)
        {
            await LoadLobbyStateAsync();
            roomError = "Не удалось создать комнату.";
            return;
        }

        Navigation.NavigateTo($"/game/room/{room.Code}");
    }

    private void OpenJoinRoomModal()
    {
        if (HasActiveGame)
            return;

        joinRoomModalError = null;
        joinRoomCode = string.Empty;
        isJoinRoomModalOpen = true;
    }

    private void CloseJoinRoomModal()
    {
        if (isJoiningRoom)
            return;

        isJoinRoomModalOpen = false;
        joinRoomModalError = null;
        joinRoomCode = string.Empty;
    }

    private async Task JoinRoomAsync()
    {
        if (isJoiningRoom || HasActiveGame)
            return;

        if (string.IsNullOrWhiteSpace(joinRoomCode))
        {
            joinRoomModalError = "Введите код комнаты.";
            return;
        }

        isJoiningRoom = true;
        joinRoomModalError = null;
        roomError = null;

        var room = await RoomService.JoinRoomAsync(joinRoomCode);

        isJoiningRoom = false;

        if (room is null)
        {
            await LoadLobbyStateAsync();
            joinRoomModalError = "Комната не найдена, уже заполнена или у тебя есть активная игра.";
            return;
        }

        CloseJoinRoomModal();
        Navigation.NavigateTo($"/game/room/{room.Code}");
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
    }
}

@page "/"
@implements IDisposable
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState

<PageTitle>GuessWord</PageTitle>

<div class="home-page">
    <div class="home-top-grid">
        <section class="home-card home-card-primary">
            <h1 class="home-title">Guess Word</h1>

            <p class="home-description">
                Соревнуйся в угадывании слов, тренируй интуицию и побеждай друзей в каждом раунде.
            </p>

            <div class="home-actions">
                <button class="home-button home-button-dark" @onclick="NavigateToPrimaryAction" type="button">
                    @PrimaryActionText
                </button>
                <button class="home-button home-button-light" @onclick="NavigateToSecondaryAction" type="button">
                    @SecondaryActionText
                </button>
            </div>
        </section>

        <aside class="home-card home-card-light">
            <h2 class="home-side-title">Быстрый старт</h2>

            <p class="home-side-text">
                @QuickStartText
            </p>
        </aside>
    </div>

    <div class="home-benefits">
        <section class="home-card-accent">
            <h2 class="home-benefit-title">Интеллект</h2>
            <p class="home-benefit-text">Тренируй ассоциации и словарный запас в каждом матче.</p>
        </section>

        <section class="home-card-accent">
            <h2 class="home-benefit-title">Соревнование</h2>
            <p class="home-benefit-text">Сравнивай результаты и побеждай друзей в быстрых дуэлях.</p>
        </section>

        <section class="home-card-accent">
            <h2 class="home-benefit-title">Обучение</h2>
            <p class="home-benefit-text">Находи новые связи между словами и становись сильнее с каждой игрой.</p>
        </section>
    </div>

    <div class="home-bottom-grid">
        <div class="home-links">
            <button class="home-pill-link" @onclick="NavigateToProfile" type="button">Профиль</button>
            <button class="home-pill-link" @onclick='() => NavigateTo("/leaderboard")' type="button">Таблица лидеров</button>
            <button class="home-pill-link" @onclick="NavigateToHistory" type="button">История матчей</button>
        </div>

        <section class="home-card home-card-primary home-rules">
            <h2 class="home-rules-title">Как играть</h2>

            <ol class="home-rules-list">
                <li>Введи слово-предположение и отправь попытку.</li>
                <li>Смотри на ранг слова, чтобы понять, насколько ты близко.</li>
                <li>Повторяй попытки, пока не найдешь загаданное слово.</li>
            </ol>
        </section>
    </div>
</div>

@code {
    private bool IsAuthorized => UserState.IsAuthorized;

    private string PrimaryActionText => IsAuthorized ? "Одиночная игра" : "Зарегистрироваться";

    private string SecondaryActionText => IsAuthorized ? "Игра 1 на 1" : "Войти";

    private string QuickStartText => IsAuthorized
        ? "Угадай слово за минимум попыток, отслеживай лучший ранг и открывай новые серии побед."
        : "Для  того чтобы начать играть, войдите в систему.";

    protected override void OnInitialized()
    {
        UserState.OnChange += HandleUserStateChanged;
    }

    private void HandleUserStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void NavigateToPrimaryAction()
    {
        NavigateTo(IsAuthorized ? "/game" : "/register");
    }

    private void NavigateToSecondaryAction()
    {
        NavigateTo(IsAuthorized ? "/game" : "/login");
    }

    private void NavigateToProfile()
    {
        NavigateTo(IsAuthorized ? "/profile" : "/login");
    }

    private void NavigateToHistory()
    {
        NavigateTo(IsAuthorized ? "/history" : "/login");
    }

    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
    }
}

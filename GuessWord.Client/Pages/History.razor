@page "/history"
@implements IDisposable
@inject NavigationManager Navigation
@inject GuessWord.Client.Services.UserStateService UserState
@inject GuessWord.Client.Services.GameService GameService

<PageTitle>История матчей</PageTitle>

<div class="history-page">
    @if (!UserState.IsInitialized || _isLoading)
    {
        <section class="history-card history-empty-card">
            <h1 class="history-empty-title">История матчей</h1>
            <p class="history-empty-text">Загрузка...</p>
        </section>
    }
    else if (!UserState.IsAuthorized)
    {
        <section class="history-card history-empty-card">
            <h1 class="history-empty-title">История матчей</h1>
            <p class="history-empty-text">Войдите в аккаунт, чтобы смотреть историю матчей.</p>
            <button class="history-login-button" @onclick="NavigateToLogin" type="button">Войти</button>
        </section>
    }
    else
    {
        <section class="history-card history-header">
            <div class="history-header-content">
                <h1 class="history-title">История матчей</h1>
                <p class="history-subtitle">Последние игры и результаты</p>
            </div>

            <div class="history-header-actions">
                <button class="history-filter-button" @onclick="CycleFilter" type="button">
                    Фильтр: @FilterLabel
                </button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <p class="history-empty-result">@_errorMessage</p>
        }
        else if (FilteredMatches.Count == 0)
        {
            <p class="history-empty-result">Матчи не найдены.</p>
        }
        else
        {
            <div class="history-table-wrap">
                <div class="history-table">
                    <div class="history-table-header">
                        <div>Дата</div>
                        <div>Тип игры</div>
                        <div>Результат</div>
                        <div>Попытки</div>
                        <div>Слово</div>
                        <div>Соперник</div>
                    </div>

                    <div class="history-table-body">
                        @foreach (var match in FilteredMatches)
                        {
                            <div class="history-row">
                                <div>@match.Date.ToLocalTime().ToString("dd.MM.yy")</div>
                                <div>@match.GameType</div>
                                <div>@match.Result</div>
                                <div>@match.AttemptsCount</div>
                                <div>@match.SecretWord</div>
                                <div>@(string.IsNullOrWhiteSpace(match.OpponentName) ? "-" : match.OpponentName)</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private MatchFilter _selectedFilter = MatchFilter.All;
    private List<GuessWord.Shared.Responses.GameHistoryItemResponseDto> _matches = [];
    private bool _isLoading;
    private string? _errorMessage;

    private List<GuessWord.Shared.Responses.GameHistoryItemResponseDto> FilteredMatches => _matches
        .Where(match => _selectedFilter == MatchFilter.All || MapFilter(match.GameType) == _selectedFilter)
        .ToList();

    private string FilterLabel => _selectedFilter switch
    {
        MatchFilter.Single => "сингл",
        MatchFilter.Multiplayer => "мультиплеер",
        _ => "все"
    };

    protected override async Task OnInitializedAsync()
    {
        UserState.OnChange += HandleUserStateChanged;
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _matches = [];
        _errorMessage = null;

        if (!UserState.IsInitialized)
        {
            _isLoading = true;
            return;
        }

        if (!UserState.IsAuthorized)
        {
            _isLoading = false;
            return;
        }

        _isLoading = true;
        StateHasChanged();

        var history = await GameService.GetHistoryAsync();
        _matches = history ?? [];
        _errorMessage = history is null ? "Не удалось загрузить историю матчей." : null;
        _isLoading = false;
    }

    private void HandleUserStateChanged()
    {
        _ = InvokeAsync(LoadHistoryAsync);
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void CycleFilter()
    {
        _selectedFilter = _selectedFilter switch
        {
            MatchFilter.All => MatchFilter.Single,
            MatchFilter.Single => MatchFilter.Multiplayer,
            _ => MatchFilter.All
        };
    }

    private static MatchFilter MapFilter(string gameType)
    {
        return gameType switch
        {
            "Сингл" => MatchFilter.Single,
            "Мультиплеер" => MatchFilter.Multiplayer,
            _ => MatchFilter.All
        };
    }

    public void Dispose()
    {
        UserState.OnChange -= HandleUserStateChanged;
    }

    private enum MatchFilter
    {
        All,
        Single,
        Multiplayer
    }
}

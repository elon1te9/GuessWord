@page "/login"
@inject GuessWord.Client.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-title">Авторизация</div>

        <div class="auth-field">
            <label class="auth-label">Логин:</label>
            <input class="auth-input" @bind="login" placeholder="Логин" />
        </div>

        <div class="auth-field">
            <label class="auth-label">Пароль:</label>
            <input class="auth-input" type="password" @bind="password" placeholder="Пароль" />
        </div>

        <div class="auth-message">@errorMessage</div>

        <button class="auth-button" @onclick="LoginUser" type="button">
            Войти
        </button>

        <div class="auth-footer-text">
            <span class="auth-footer-question">Еще нет аккаунта?</span>
            <a href="/register">Зарегистрироваться</a>
        </div>
    </div>
</div>

@code {
    private string login = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task LoginUser()
    {
        if (string.IsNullOrWhiteSpace(login) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Заполните все поля!";
            return;
        }

        errorMessage = string.Empty;

        var result = await AuthService.Login(new GuessWord.Shared.Requests.LoginRequestDto
        {
            Login = login,
            Password = password
        });

        if (result is null)
        {
            errorMessage = "Неверный логин или пароль.";
            return;
        }

        Navigation.NavigateTo("/");
    }
}